# ----------------------------------------------------------------              
# CONFIGURATION DE SÉCURITÉ - PROJET RCM_LYS
# ----------------------------------------------------------------
# INSTRUCTIONS : 
# 1. Copiez ce fichier et renommez-le en ".env"
# 2. Ne jamais commiter le fichier ".env" (déjà dans .gitignore)
# ----------------------------------------------------------------

# PORT du serveur (ex: 3000)
PORT=3000

# CLÉ SECRÈTE JWT (Utilisée pour signer et vérifier les tokens)
# En local : Mettez une chaîne de caractères longue et complexe.
# En Prod : Cette valeur est gérée via les GitHub Secrets.
JWT_SECRET=remplacer_par_une_cle_secrete_de_test_32_chars_min

# CONFIGURATION BASE DE DONNÉES (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=votre_password_local
DB_NAME=rcm_lys_db

# SERVICES TIERS
STRIPE_KEY=votre_cle_test_stripe
