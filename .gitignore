# --- DÉPENDANCES  ---
# Ne jamais commit ce dossier, il est généré par 'npm install'
node_modules/
/jspm_packages/

# --- SÉCURITÉ & ENVIRONNEMENT  ---
# Fichiers contenant les clés API, tokens et secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# Autoriser explicitement le fichier d'exemple (le modèle)
!.env.example

# --- BUILDS & PRODUCTION ---
# Dossiers générés lors du 'npm run build'
dist/
build/
.pnp
.pnp.js

# --- LOGS ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# --- TESTS ---
/coverage
/.nyc_output

# --- IDE & SYSTÈME ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- CACHE ---
.eslintcache
.stylelintcache
.node_repl_history
.cache/

# --- DATA & BASES DE DONNÉES ---
# Ne jamais versionner de données réelles ou de fichiers DB
*.db
*.sqlite
*.sqlite3
*.sql
*.sql.gz
dump.sql
/data/
